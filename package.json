{
  "name": "pi-revit",
  "version": "0.2.12",
  "description": "Native Pi connector for Autodesk Revit. Run npx.cmd -y pi-revit for the full Windows install.",
  "author": "Ahmad Altahlawi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Triavision-ai/pi-revit.git"
  },
  "bugs": {
    "url": "https://github.com/Triavision-ai/pi-revit/issues"
  },
  "homepage": "https://github.com/Triavision-ai/pi-revit#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "revit",
    "bim",
    "autodesk",
    "revit-api"
  ],
  "bin": {
    "pi-revit": "bin/pi-revit.js"
  },
  "scripts": {
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-workspace.ps1",
    "uninstall:revit": "powershell -ExecutionPolicy Bypass -File scripts/uninstall.ps1"
  },
  "files": [
    "bin/",
    "extensions/",
    "skills/",
    "scripts/",
    "src/",
    "workspace/",
    "README.md",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/pi-revit/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "engines": {
    "node": ">=20.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  }
}
